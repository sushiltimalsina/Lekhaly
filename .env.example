# Environment Variables
# Copy this file to .env and fill in the values

# API
API_PORT=4000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lekhaly_accounting?schema=public"

# Redis (for caching / rate limiting)
REDIS_URL="redis://localhost:6379"

# JWT Secrets — generate strong random values for production!
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# JWT_ISSUER=lekhaly
# JWT_AUDIENCE=lekhaly-app

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# CORS — comma-separated origins allowed in production
CORS_ORIGINS=http://localhost:3000
