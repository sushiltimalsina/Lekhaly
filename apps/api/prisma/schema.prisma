generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
}

enum PartyType {
  customer
  supplier
  both
}

enum CoaType {
  asset
  liability
  equity
  income
  expense
}

enum VoucherType {
  sales_invoice
  sales_return
  purchase
  purchase_return
  receipt
  payment
  journal
  opening
  reversal
  contra
}

enum VoucherStatus {
  draft
  pending_post
  posted
  void
}

enum ItemType {
  goods
  services
}

enum AuditActorType {
  user
  system
  sync
  api_client
  ai_client
}

enum ChangeOp {
  upsert
  delete
  command
}

enum OutboxStatus {
  pending
  processed
  failed
}

enum PdfJobStatus {
  pending
  processing
  done
  failed
}

model Company {
  id           String @id @default(uuid())
  code         String? @unique
  name         String
  baseCurrency String @default("NPR")
  timezone     String @default("Asia/Kathmandu")

  fiscalYearStartMonth Int @default(4) // Nepal common FY start is mid-April; UI can configure.

  // Profile Information
  address             String?
  phone               String?
  email               String?
  panNumber           String?
  vatNumber           String?

  // numbering + lock settings
  invoicePrefix       String    @default("SI")
  purchasePrefix      String    @default("PURI")
  salesReturnPrefix   String    @default("SR")
  purchaseReturnPrefix String   @default("PR")
  orderPrefix         String    @default("SO")
  quotationPrefix     String    @default("QT")
  purchaseOrderPrefix String    @default("PO")
  receiptPrefix       String    @default("RV")
  paymentPrefix       String    @default("PV")
  journalPrefix       String    @default("JV")
  contraPrefix        String    @default("CV")

  invoiceSuffix       String    @default("80/81")
  purchaseSuffix      String    @default("80/81")
  salesReturnSuffix   String    @default("80/81")
  purchaseReturnSuffix String   @default("80/81")
  orderSuffix         String    @default("80/81")
  quotationSuffix     String    @default("80/81")
  purchaseOrderSuffix String    @default("80/81")
  receiptSuffix       String    @default("80/81")
  paymentSuffix       String    @default("80/81")
  journalSuffix       String    @default("80/81")
  contraSuffix        String    @default("80/81")

  nextInvoiceNumber   Int       @default(1)
  nextPurchaseNumber  Int       @default(1)
  nextSalesReturnNumber Int     @default(1)
  nextPurchaseReturnNumber Int   @default(1)
  nextOrderNumber     Int       @default(1)
  nextQuotationNumber Int       @default(1)
  nextPurchaseOrderNumber Int @default(1)
  nextReceiptNumber   Int       @default(1)
  nextPaymentNumber   Int       @default(1)
  nextJournalNumber   Int       @default(1)
  nextContraNumber    Int       @default(1)

  lockDate            DateTime?
  creditLimitAmount   Decimal   @default(0) @db.Decimal(14, 2)
  printLogo           Boolean   @default(true)

  activeFiscalSessionId String?
  fiscalSessions        FiscalSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  roles              Role[]
  parties            Party[]
  items              Item[]
  itemGroups         ItemGroup[]
  units              Unit[]
  taxCodes           TaxCode[]
  invoices           Invoice[]
  stockLedger        StockLedger[]
  expenses           Expense[]
  vatRegisterLines   VatRegisterLine[]
  bankAccounts       BankAccount[]
  bankStatements     BankStatement[]
  bankStatementLines BankStatementLine[]
  accounts           ChartOfAccount[]
  vouchers           Voucher[]
  voucherLines       VoucherLine[]
  voucherAttachments VoucherAttachment[]
  devices            Device[]
  auditLogs          AuditLog[]
  snapshots          AuditSnapshot[]
  syncStates         SyncState[]
  apiIdempotencies   ApiIdempotency[]
  outboxEvents       OutboxEvent[]
  pdfJobs            PdfJob[]
  billSundries       BillSundry[]
  quotations         Quotation[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  proformaInvoices   ProformaInvoice[]

  changeLog ChangeLog[]
}

model User {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  email        String
  name         String?
  passwordHash String
  status       UserStatus @default(active)

  totpEnabled          Boolean @default(false)
  totpSecretEnc        String?
  trustedDeviceVersion Int     @default(0)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userRoles       UserRole[]
  sessions        AuthSession[]
  backupCodes     BackupCode[]
  createdVouchers Voucher[]     @relation("VoucherCreatedBy")
  postedVouchers  Voucher[]     @relation("VoucherPostedBy")
  voidedVouchers  Voucher[]     @relation("VoucherVoidedBy")
    auditLogs       AuditLog[]
    changeLogs      ChangeLog[]
    uploadedVoucherAttachments VoucherAttachment[]

  deviceLinks DeviceUserLink[]
  apiIdempotencies ApiIdempotency[]

  @@unique([companyId, email])
  @@index([companyId, status])
}

model Role {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, name])
}

model Permission {
  code        String @id
  description String

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId         String
  permissionCode String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionCode], references: [code])

  @@id([roleId, permissionCode])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model AuthSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  refreshTokenHash String
  deviceId         String?
  trustedUntil     DateTime?

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
}

model BackupCode {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Party {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type PartyType @default(customer)
  name String

  email   String?
  phone   String?
  address String?

  // Nepal identifiers (keep both; validate format in app layer)
  panNumber String?
  vatNumber String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouchers     Voucher[]
  voucherLines VoucherLine[]
  expenses     Expense[]
  vatRegisterLines VatRegisterLine[]
  invoices     Invoice[]
  quotations   Quotation[]
  salesOrders  SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@index([companyId, type, isActive])
  @@index([companyId, name])
}

model ChartOfAccount {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code     String
  name     String
  type     CoaType
  level    Int      @default(0)
  isGroup  Boolean  @default(false)
  parentId String?
  parent   ChartOfAccount?  @relation("CoaTree", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("CoaTree")

  isPostable Boolean @default(true)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voucherLines   VoucherLine[]
  incomeItems    Item[]        @relation("IncomeAccount")
  expenseItems   Item[]        @relation("ExpenseAccount")
  // Back-relations for Tax codes
    inputTaxCodes  TaxCode[]     @relation("TaxInputAccount")
    outputTaxCodes TaxCode[]     @relation("TaxOutputAccount")
    bankAccounts   BankAccount[]
    invoices       Invoice[]     @relation("InvoiceReceivableAccount")
    billSundries   BillSundry[]
    invoiceSundries InvoiceSundry[]
    quotationSundries QuotationSundry[]
    salesOrderSundries SalesOrderSundry[]
    purchaseOrderSundries PurchaseOrderSundry[]

  @@unique([companyId, code])
  @@index([companyId, type])
}

model TaxCode {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String
  rate        Decimal @db.Decimal(10, 2) // e.g. 13.00
  isInclusive Boolean @default(false)

  inputTaxAccountId String?
  inputTaxAccount   ChartOfAccount? @relation("TaxInputAccount", fields: [inputTaxAccountId], references: [id])

  outputTaxAccountId String?
  outputTaxAccount   ChartOfAccount? @relation("TaxOutputAccount", fields: [outputTaxAccountId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voucherLines     VoucherLine[]
  items            Item[]
  itemTaxCodes     ItemTaxCode[]
  invoiceItems     InvoiceItem[]
  invoiceItemTaxes InvoiceItemTax[]
  quotationItems   QuotationItem[]
  salesOrderItems  SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  expenses         Expense[]
  vatRegisterLines VatRegisterLine[]

  @@index([companyId, isActive])
}

model BillSundry {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  type      String   @default("add") // add | less
  rate      Decimal? @db.Decimal(10, 2)
  accountId String?
  account   ChartOfAccount? @relation(fields: [accountId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceSundries InvoiceSundry[]
  quotationSundries QuotationSundry[]
  salesOrderSundries SalesOrderSundry[]
  purchaseOrderSundries PurchaseOrderSundry[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model BankAccount {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accountId String
  account   ChartOfAccount @relation(fields: [accountId], references: [id])

  bankName      String?
  accountNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statements BankStatement[]

  @@unique([companyId, accountId])
  @@index([companyId, createdAt])
}

model BankStatement {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])

    periodFrom     DateTime
    periodFromBs   String?
    periodTo       DateTime
    periodToBs     String?
  openingBalance Decimal @db.Decimal(14, 2)
  closingBalance Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines BankStatementLine[]

  @@index([companyId, bankAccountId, periodFrom, periodTo])
}

model BankStatementLine {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  statementId String
  statement   BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

    date        DateTime
    dateBs      String?
  description String?
  amount      Decimal @db.Decimal(14, 2)
  debitCredit String // debit | credit

  matchedVoucherId String?
  matchedVoucher   Voucher? @relation(fields: [matchedVoucherId], references: [id])

  matchedLineId String?
  matchedLine   VoucherLine? @relation(fields: [matchedLineId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId, statementId, date])
}

model Item {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  groupId String?
  group   ItemGroup? @relation(fields: [groupId], references: [id])

  name String
  sku  String?
  hsCode String?
  unit String?
  type ItemType @default(goods)

  salesPrice    Decimal? @db.Decimal(14, 2)
  purchasePrice Decimal? @db.Decimal(14, 2)

  incomeAccountId String?
  incomeAccount   ChartOfAccount? @relation("IncomeAccount", fields: [incomeAccountId], references: [id])

  expenseAccountId String?
  expenseAccount   ChartOfAccount? @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])

  taxCodeId    String?
  taxCode      TaxCode? @relation(fields: [taxCodeId], references: [id])
  itemTaxCodes ItemTaxCode[]
  voucherLines VoucherLine[]
  invoiceItems InvoiceItem[]
  quotationItems QuotationItem[]
  salesOrderItems SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLedger StockLedger[]

  @@unique([companyId, name])
}

model Unit {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model ItemGroup {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@unique([companyId, name])
}

model ItemTaxCode {
  id        String  @id @default(uuid())
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  taxCodeId String
  taxCode   TaxCode @relation(fields: [taxCodeId], references: [id])

  @@unique([itemId, taxCodeId])
}

model Voucher {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  voucherType VoucherType
  status      VoucherStatus @default(draft)

  voucherNumber String?
  referenceNo   String?
  voucherDate   DateTime
  voucherDateBs String?

  vendorInvoiceNo   String?
  vendorInvoiceDate DateTime?

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id])

  memo String?
  additionalNote String? @db.Text

  source String @default("api") // web|desktop|sync|ai_client later

  createdByUserId String?
  createdByUser   User?   @relation("VoucherCreatedBy", fields: [createdByUserId], references: [id])

  postedByUserId String?
  postedByUser   User?   @relation("VoucherPostedBy", fields: [postedByUserId], references: [id])

  voidedByUserId String?
  voidedByUser   User?   @relation("VoucherVoidedBy", fields: [voidedByUserId], references: [id])

  postedAt DateTime?
  voidedAt DateTime?

  reversalOfVoucherId String?
  reversalOfVoucher   Voucher?  @relation("VoucherReversal", fields: [reversalOfVoucherId], references: [id])
  reversals           Voucher[] @relation("VoucherReversal")

  revisionOfVoucherId String?
  revisionOfVoucher   Voucher?  @relation("VoucherRevision", fields: [revisionOfVoucherId], references: [id])
  revisions           Voucher[] @relation("VoucherRevision")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    lines VoucherLine[]
  attachments VoucherAttachment[]
  bankStatementLines BankStatementLine[]
  invoice Invoice?
  stockLedger StockLedger[]
  expenses Expense[]
  vatRegisterLines VatRegisterLine[]
  proformas ProformaInvoice[]

  fiscalSessionId String?
  fiscalSession   FiscalSession? @relation(fields: [fiscalSessionId], references: [id])

  @@unique([companyId, voucherNumber])
  @@index([companyId, status, voucherDate])
}

model Invoice {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  voucherId String? @unique
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  invoiceNo   String?
  referenceNo String?
  type        String // sales | sales_return

  partyId String
  party   Party @relation(fields: [partyId], references: [id])

  receivableAccountId String
  receivableAccount   ChartOfAccount @relation("InvoiceReceivableAccount", fields: [receivableAccountId], references: [id])

  date    DateTime
  dateBs  String?
  dueDate DateTime?
  dueDateBs String?

  subtotal  Decimal @db.Decimal(14, 2)
  vatAmount Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)
  status    String
  memo      String?
  additionalNote String? @db.Text

  items     InvoiceItem[]
  sundries  InvoiceSundry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, date])
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  itemId String?
  item   Item? @relation(fields: [itemId], references: [id])

  description String?
  qty         Decimal @db.Decimal(14, 2)
  rate        Decimal @db.Decimal(14, 2)
  amount      Decimal @db.Decimal(14, 2)

  taxCodeId String?
  taxCode   TaxCode? @relation(fields: [taxCodeId], references: [id])
  taxAmount Decimal @db.Decimal(14, 2)
  taxes     InvoiceItemTax[]

  createdAt DateTime @default(now())
}

model InvoiceItemTax {
  id            String  @id @default(uuid())
  invoiceItemId String
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  taxCodeId     String
  taxCode       TaxCode @relation(fields: [taxCodeId], references: [id])
  taxAmount     Decimal @db.Decimal(14, 2)

  @@unique([invoiceItemId, taxCodeId])
}

model InvoiceSundry {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  billSundryId String?
  billSundry   BillSundry? @relation(fields: [billSundryId], references: [id])

  name      String
  type      String   // add | less
  rate      Decimal? @db.Decimal(10, 2)
  amount    Decimal  @db.Decimal(14, 2)
  
  accountId String?
  account   ChartOfAccount? @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
}

model StockLedger {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  itemId String
  item   Item @relation(fields: [itemId], references: [id])

  date     DateTime
  dateBs   String?
  voucherId String?
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  qtyIn  Decimal @db.Decimal(14, 2)
  qtyOut Decimal @db.Decimal(14, 2)
  rate   Decimal @db.Decimal(14, 2)
  amount Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  @@index([companyId, itemId, date])
}

  model VoucherLine {
  id String @id @default(uuid())

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  lineNo Int

  accountId String
  account   ChartOfAccount @relation(fields: [accountId], references: [id])

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id])

  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  description String?

  debit  Decimal @default(0) @db.Decimal(14, 2)
  credit Decimal @default(0) @db.Decimal(14, 2)

  qty    Decimal @default(0) @db.Decimal(14, 2)

  taxCodeId String?
  taxCode   TaxCode? @relation(fields: [taxCodeId], references: [id])

    taxAmount Decimal @default(0) @db.Decimal(14, 2)

    createdAt DateTime @default(now())

    bankStatementLines BankStatementLine[]

    @@index([companyId, accountId, createdAt])
    @@index([companyId, partyId, createdAt])
  }

model VoucherAttachment {
    id        String  @id @default(uuid())
    companyId String
    company   Company @relation(fields: [companyId], references: [id])

    voucherId String
    voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

    uploadedByUserId String?
    uploadedByUser   User? @relation(fields: [uploadedByUserId], references: [id])

    fileName   String
    mimeType   String
    sizeBytes  Int
    storageKey String

  createdAt DateTime @default(now())

  @@index([companyId, voucherId, createdAt])
  expenses Expense[]
}

model Expense {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  voucherId String? @unique
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  date       DateTime
  dateBs     String?
  vendorId   String?
  vendor     Party? @relation(fields: [vendorId], references: [id])
  amount     Decimal @db.Decimal(14, 2)
  taxCodeId  String?
  taxCode    TaxCode? @relation(fields: [taxCodeId], references: [id])
  description String?
  attachmentId String?
  attachment   VoucherAttachment? @relation(fields: [attachmentId], references: [id])

  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, date])
}

model VatRegisterLine {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id])

  date    DateTime
  partyId String?
  party   Party? @relation(fields: [partyId], references: [id])

  taxableAmount Decimal @db.Decimal(14, 2)
  vatAmount     Decimal @db.Decimal(14, 2)
  type          String // sales | purchase

  taxCodeId String?
  taxCode   TaxCode? @relation(fields: [taxCodeId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId, date])
}

model AuditSnapshot {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  entityType   String
  entityId     String
  snapshotJson Json
  hash         String

  createdAt DateTime @default(now())

  auditLogsBefore AuditLog[] @relation("AuditBefore")
  auditLogsAfter  AuditLog[] @relation("AuditAfter")
}

model AuditLog {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  actorType   AuditActorType
  actorUserId String?
  actorUser   User?          @relation(fields: [actorUserId], references: [id])

  actorDeviceId String?
  actorDevice   Device? @relation(fields: [actorDeviceId], references: [id])

  action     String
  entityType String
  entityId   String

  requestId String?
  ip        String?
  userAgent String?

  beforeSnapshotId String?
  beforeSnapshot   AuditSnapshot? @relation("AuditBefore", fields: [beforeSnapshotId], references: [id])

  afterSnapshotId String?
  afterSnapshot   AuditSnapshot? @relation("AuditAfter", fields: [afterSnapshotId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, entityType, entityId])
}

model Device {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  label    String
  platform String // windows|mac|linux|web
  trusted  Boolean @default(false)

  // Proforma (offline) numbering
  proformaPrefix   String?
  proformaSequence Int @default(1)

  lastSeenAt DateTime?
  createdAt  DateTime   @default(now())
  auditLogs  AuditLog[]

  deviceUsers DeviceUserLink[]
  changeLog   ChangeLog[]
  syncState   SyncState?
  proformas   ProformaInvoice[]
}

model DeviceUserLink {
  id       String @id @default(uuid())
  deviceId String
  userId   String

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([deviceId, userId])
}

model ChangeLog {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])

  seq            BigInt
  entityType     String
  entityId       String
  op             ChangeOp
  payload        Json
  idempotencyKey String?

  createdAt DateTime @default(now())

  @@unique([deviceId, seq])
  @@index([companyId, createdAt])
}

model SyncState {
  id        String @id @default(uuid())
  companyId String
  deviceId  String @unique

  company Company @relation(fields: [companyId], references: [id])
  device  Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  lastPulledChangeId String?
  updatedAt          DateTime @updatedAt
}

model ProformaInvoice {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  localNumber String   // e.g. "PRF-D1-001"
  voucherId   String?  // linked after conversion to real voucher
  voucher     Voucher? @relation(fields: [voucherId], references: [id])

  voucherType VoucherType
  payload     Json          // full voucher draft data for offline print
  memo        String?

  convertedAt DateTime?     // set when converted to real posted voucher
  createdAt   DateTime @default(now())

  @@unique([companyId, localNumber])
  @@index([companyId, convertedAt])
}

model ApiIdempotency {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  key       String
  action    String
  requestHash String?
  responseJson Json
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([companyId, key, action])
  @@index([companyId, createdAt])
}

model OutboxEvent {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type   String
  status OutboxStatus @default(pending)
  payload Json

  createdAt   DateTime @default(now())
  processedAt DateTime?
  lastError   String?
  attempts    Int      @default(0)
  nextAttemptAt DateTime?

  @@index([companyId, status, createdAt])
  @@index([status, nextAttemptAt])
}

model PdfJob {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type   String
  status PdfJobStatus @default(pending)
  payload Json
  resultKey String?
  error     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status, createdAt])
}

enum QuotationStatus {
  draft
  sent
  accepted
  declined
  expired
}

enum SalesOrderStatus {
  draft
  open
  fulfilled
  cancelled
}

enum PurchaseOrderStatus {
  draft
  open
  received
  cancelled
}

model Quotation {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  quotationNo String?
  referenceNo String?
  status      QuotationStatus @default(draft)

  partyId String
  party   Party @relation(fields: [partyId], references: [id])

  date    DateTime
  dateBs  String?
  expiryDate DateTime?
  expiryDateBs String?

  subtotal  Decimal @db.Decimal(14, 2)
  vatAmount Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)

  memo      String?
  additionalNote String? @db.Text
  terms      String? @db.Text

  items     QuotationItem[]
  sundries  QuotationSundry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders SalesOrder[]

  @@unique([companyId, quotationNo])
  @@index([companyId, date])
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  itemId      String?
  item        Item?     @relation(fields: [itemId], references: [id])

  description String?
  qty         Decimal   @db.Decimal(14, 2)
  rate        Decimal   @db.Decimal(14, 2)
  amount      Decimal   @db.Decimal(14, 2)

  taxCodeId   String?
  taxCode     TaxCode?  @relation(fields: [taxCodeId], references: [id])
  taxAmount   Decimal   @db.Decimal(14, 2)

  createdAt   DateTime  @default(now())
}

model QuotationSundry {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  billSundryId String?
  billSundry   BillSundry? @relation(fields: [billSundryId], references: [id])

  name        String
  type        String   // add | less
  rate        Decimal? @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(14, 2)

  accountId   String?
  account     ChartOfAccount? @relation(fields: [accountId], references: [id])

  createdAt   DateTime  @default(now())
}

model SalesOrder {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  orderNo     String?
  customerPoRef String?
  status      SalesOrderStatus @default(draft)

  partyId String
  party   Party @relation(fields: [partyId], references: [id])

  date    DateTime
  dateBs  String?
  expectedDelivery DateTime?
  expectedDeliveryBs String?

  subtotal  Decimal @db.Decimal(14, 2)
  vatAmount Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)

  memo      String?
  additionalNote String? @db.Text
  terms      String? @db.Text

  items     SalesOrderItem[]
  sundries  SalesOrderSundry[]

  quotationId String?
  quotation   Quotation? @relation(fields: [quotationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, orderNo])
  @@index([companyId, date])
}

model SalesOrderItem {
  id          String     @id @default(uuid())
  orderId     String
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId      String?
  item        Item?      @relation(fields: [itemId], references: [id])

  description String?
  qty         Decimal    @db.Decimal(14, 2)
  rate        Decimal    @db.Decimal(14, 2)
  amount      Decimal    @db.Decimal(14, 2)

  fulfilledQty Decimal   @default(0) @db.Decimal(14, 2)

  taxCodeId   String?
  taxCode     TaxCode?   @relation(fields: [taxCodeId], references: [id])
  taxAmount   Decimal    @db.Decimal(14, 2)

  createdAt   DateTime   @default(now())
}

model SalesOrderSundry {
  id          String     @id @default(uuid())
  orderId     String
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  billSundryId String?
  billSundry   BillSundry? @relation(fields: [billSundryId], references: [id])

  name        String
  type        String   // add | less
  rate        Decimal? @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(14, 2)

  accountId   String?
  account     ChartOfAccount? @relation(fields: [accountId], references: [id])

  createdAt   DateTime   @default(now())
}

model PurchaseOrder {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  orderNo     String?
  status      PurchaseOrderStatus @default(draft)

  partyId String
  party   Party @relation(fields: [partyId], references: [id])

  date    DateTime
  dateBs  String?
  expectedDelivery DateTime?
  expectedDeliveryBs String?

  subtotal  Decimal @db.Decimal(14, 2)
  vatAmount Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)

  memo      String?
  additionalNote String? @db.Text
  terms      String? @db.Text

  items     PurchaseOrderItem[]
  sundries  PurchaseOrderSundry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, orderNo])
  @@index([companyId, date])
}

model PurchaseOrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId      String?
  item        Item?         @relation(fields: [itemId], references: [id])

  description String?
  qty         Decimal       @db.Decimal(14, 2)
  rate        Decimal       @db.Decimal(14, 2)
  amount      Decimal       @db.Decimal(14, 2)

  receivedQty Decimal       @default(0) @db.Decimal(14, 2)

  taxCodeId   String?
  taxCode     TaxCode?      @relation(fields: [taxCodeId], references: [id])
  taxAmount   Decimal       @db.Decimal(14, 2)

  createdAt   DateTime      @default(now())
}

model PurchaseOrderSundry {
  id          String        @id @default(uuid())
  orderId     String
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  billSundryId String?
  billSundry   BillSundry? @relation(fields: [billSundryId], references: [id])

  name        String
  type        String   // add | less
  rate        Decimal? @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(14, 2)

  accountId   String?
  account     ChartOfAccount? @relation(fields: [accountId], references: [id])

  createdAt   DateTime      @default(now())
}
model FiscalSession {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name      String   // e.g. "Year 2080/81"
  startDate DateTime
  endDate   DateTime
  isLocked  Boolean  @default(false)

  // Session-specific numbering + lock settings
  invoicePrefix       String    @default("SI")
  purchasePrefix      String    @default("PURI")
  salesReturnPrefix   String    @default("SR")
  purchaseReturnPrefix String   @default("PR")
  orderPrefix         String    @default("SO")
  quotationPrefix     String    @default("QT")
  purchaseOrderPrefix String    @default("PO")
  receiptPrefix       String    @default("RV")
  paymentPrefix       String    @default("PV")
  journalPrefix       String    @default("JV")
  contraPrefix        String    @default("CV")

  invoiceSuffix       String    @default("80/81")
  purchaseSuffix      String    @default("80/81")
  salesReturnSuffix   String    @default("80/81")
  purchaseReturnSuffix String   @default("80/81")
  orderSuffix         String    @default("80/81")
  quotationSuffix     String    @default("80/81")
  purchaseOrderSuffix String    @default("80/81")
  receiptSuffix       String    @default("80/81")
  paymentSuffix       String    @default("80/81")
  journalSuffix       String    @default("80/81")
  contraSuffix        String    @default("80/81")

  nextInvoiceNumber   Int       @default(1)
  nextPurchaseNumber  Int       @default(1)
  nextSalesReturnNumber Int     @default(1)
  nextPurchaseReturnNumber Int   @default(1)
  nextOrderNumber     Int       @default(1)
  nextQuotationNumber Int       @default(1)
  nextPurchaseOrderNumber Int @default(1)
  nextReceiptNumber   Int       @default(1)
  nextPaymentNumber   Int       @default(1)
  nextJournalNumber   Int       @default(1)
  nextContraNumber    Int       @default(1)

  vouchers Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, isLocked])
}
